{% doc %}
  @prompt
    Design a New Collection / Category Highlight section for a luxury fashion e-commerce website.
    
    Layout & Structure:
    
    Section starts with a small uppercase label at the top (e.g. “NEW COLLECTION”)
    
    Followed by a large editorial headline with one emphasized word in italics (serif font)
    
    One short paragraph below explaining the collection philosophy in a calm, premium tone
    
    Below the text, display 3 equal-width category cards in a horizontal row (desktop) and stacked or swipeable cards on mobile.
    
    Each card should include:
    
    Soft neutral background (beige / taupe / muted stone)
    
    Small uppercase tag at top: “ECO-FRIENDLY” (or similar)
    
    Centered product image (cut-out or minimal shadow)
    
    Large serif category title (e.g. TOPS, FLARES, BIKINIS)
    
    Thin underline beneath category title
    
    Short supporting line of text (1 line only)
    
    Hover & Interaction:
    
    On hover (desktop):
    
    Subtle background darken or lighten
    
    Category title underline animates in
    
    Cursor becomes pointer
    
    Entire card is clickable
    
    Typography:
    
    Headline: Editorial serif
    
    Body + labels: Clean sans-serif
    
    Strong spacing, breathable margins
    
    Responsive Behaviour:
    
    Desktop: 3 cards in a row
    
    Tablet: 2 cards + swipe
    
    Mobile: 1 card per view with swipe gesture
    
    Text remains centered and readable without truncation
    
    Overall Feel:
    
    Premium, modern, fashion-editorial
    
    Minimal, confident, not salesy
    , I need 4 Cards on Desktop, Make it mobile friendly as I need cards horizontal in mobile view, Optimise the cards for mobile, Need Only one card at a moment in mobile, I need option to put image of my choice, Need dots at the bottom , Need very subtle dots , not like these, NEED CONTROL TO CONTROL THE SIZE OF THE CARD, I need 5  cards, I need option to show 4 at a time on desktop and one at a time on mobile, It should move left or write with swipe gesture, It should have dot for navigation, I need 5 cards but 4 to look at a time on desktop and One at a time for mobile and they have dots and swipe gesture to navigate  on both mobile and desktop, All 5 are not looking on mobile, please fix that
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-highlight-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-collection-highlight__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-collection-highlight__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-collection-highlight__label-{{ ai_gen_id }} {
    font-family: {{ block.settings.label_font.family }}, sans-serif;
    font-size: {{ block.settings.label_size }}px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: {{ block.settings.label_color }};
    margin-bottom: 20px;
    font-weight: 400;
  }

  .ai-collection-highlight__headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, serif;
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.2;
    color: {{ block.settings.headline_color }};
    margin-bottom: 24px;
    font-weight: 400;
  }

  .ai-collection-highlight__headline-{{ ai_gen_id }} em {
    font-style: italic;
    font-family: {{ block.settings.headline_font.family }}, serif;
  }

  .ai-collection-highlight__description-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, sans-serif;
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: {{ block.settings.description_color }};
    max-width: 600px;
    margin: 0 auto;
  }

  .ai-collection-highlight__cards-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin-bottom: 40px;
  }

  .ai-collection-highlight__cards-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-collection-highlight__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 3)) / 4);
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: background-color 0.3s ease;
    cursor: pointer;
    border-radius: {{ block.settings.card_border_radius }}px;
  }

  .ai-collection-highlight__card-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.card_hover_background }};
  }

  .ai-collection-highlight__card-tag-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, sans-serif;
    font-size: {{ block.settings.tag_size }}px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: {{ block.settings.tag_color }};
    margin-bottom: 20px;
    font-weight: 500;
  }

  .ai-collection-highlight__card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }

  .ai-collection-highlight__card-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .ai-collection-highlight__card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-highlight__card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collection-highlight__card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, serif;
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin-bottom: 12px;
    font-weight: 400;
    letter-spacing: 1px;
    position: relative;
    display: inline-block;
  }

  .ai-collection-highlight__card-title-underline-{{ ai_gen_id }} {
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: {{ block.settings.card_title_color }};
    transition: width 0.3s ease;
  }

  .ai-collection-highlight__card-{{ ai_gen_id }}:hover .ai-collection-highlight__card-title-underline-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-collection-highlight__card-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, sans-serif;
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.card_text_color }};
    line-height: 1.5;
  }

  .ai-collection-highlight__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
  }

  .ai-collection-highlight__dot-{{ ai_gen_id }} {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-collection-highlight__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  @media screen and (max-width: 989px) {
    .ai-collection-highlight__cards-{{ ai_gen_id }} {
      gap: 16px;
    }

    .ai-collection-highlight__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - 16px) / 2);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-highlight-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-collection-highlight__header-{{ ai_gen_id }} {
      margin-bottom: 40px;
    }

    .ai-collection-highlight__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.8 }}px;
    }

    .ai-collection-highlight__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-collection-highlight__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-collection-highlight__cards-wrapper-{{ ai_gen_id }} {
      overflow-x: hidden;
      margin-bottom: 20px;
    }

    .ai-collection-highlight__cards-{{ ai_gen_id }} {
      gap: 12px;
      padding: 0 4px;
    }

    .ai-collection-highlight__card-{{ ai_gen_id }} {
      flex: 0 0 calc(100% - 8px);
      scroll-snap-align: center;
    }

    .ai-collection-highlight__card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.8 }}px;
    }

    .ai-collection-highlight__dots-{{ ai_gen_id }} {
      display: flex;
    }
  }
{% endstyle %}

<luxury-collection-highlight-{{ ai_gen_id }}
  class="ai-collection-highlight-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-highlight__container-{{ ai_gen_id }}">
    <div class="ai-collection-highlight__header-{{ ai_gen_id }}">
      {% if block.settings.label != blank %}
        <div class="ai-collection-highlight__label-{{ ai_gen_id }}">
          {{ block.settings.label }}
        </div>
      {% endif %}

      {% if block.settings.headline != blank %}
        <h2 class="ai-collection-highlight__headline-{{ ai_gen_id }}">
          {{ block.settings.headline }}
        </h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-collection-highlight__description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}
    </div>

    <div class="ai-collection-highlight__cards-wrapper-{{ ai_gen_id }}">
      <div class="ai-collection-highlight__cards-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign card_tag_key = 'card_' | append: i | append: '_tag'
            assign card_image_key = 'card_' | append: i | append: '_image'
            assign card_title_key = 'card_' | append: i | append: '_title'
            assign card_text_key = 'card_' | append: i | append: '_text'
            assign card_link_key = 'card_' | append: i | append: '_link'

            assign card_tag = block.settings[card_tag_key]
            assign card_image = block.settings[card_image_key]
            assign card_title = block.settings[card_title_key]
            assign card_text = block.settings[card_text_key]
            assign card_link = block.settings[card_link_key]
          %}

          <a
            href="{{ card_link }}"
            class="ai-collection-highlight__card-{{ ai_gen_id }}"
            data-card-index="{{ i }}"
          >
            {% if card_tag != blank %}
              <div class="ai-collection-highlight__card-tag-{{ ai_gen_id }}">
                {{ card_tag }}
              </div>
            {% endif %}

            <div class="ai-collection-highlight__card-image-wrapper-{{ ai_gen_id }}">
              {% if card_image %}
                <img
                  src="{{ card_image | image_url: width: 600 }}"
                  alt="{{ card_image.alt | escape }}"
                  loading="lazy"
                  width="{{ card_image.width }}"
                  height="{{ card_image.height }}"
                  class="ai-collection-highlight__card-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-collection-highlight__card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            {% if card_title != blank %}
              <div class="ai-collection-highlight__card-title-{{ ai_gen_id }}">
                {{ card_title }}
                <span class="ai-collection-highlight__card-title-underline-{{ ai_gen_id }}"></span>
              </div>
            {% endif %}

            {% if card_text != blank %}
              <div class="ai-collection-highlight__card-text-{{ ai_gen_id }}">
                {{ card_text }}
              </div>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    </div>

    <div class="ai-collection-highlight__dots-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        <button
          class="ai-collection-highlight__dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
          data-dot-index="{{ i }}"
          aria-label="Go to slide {{ i }}"
        ></button>
      {% endfor %}
    </div>
  </div>
</luxury-collection-highlight-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxuryCollectionHighlight{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.totalSlides = 5;
        this.touchStartX = 0;
        this.touchEndX = 0;
        this.isMobile = false;
      }

      connectedCallback() {
        this.cardsContainer = this.querySelector('.ai-collection-highlight__cards-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-collection-highlight__dot-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-collection-highlight__card-{{ ai_gen_id }}');

        this.checkViewport();
        this.setupCarousel();

        window.addEventListener('resize', () => {
          this.checkViewport();
          this.updateCarousel();
        });
      }

      checkViewport() {
        this.isMobile = window.innerWidth <= 749;
      }

      setupCarousel() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
          });
        });

        this.cardsContainer.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
        });

        this.cardsContainer.addEventListener('touchend', (e) => {
          this.touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe();
        });

        this.cardsContainer.addEventListener('mousedown', (e) => {
          this.touchStartX = e.screenX;
          this.isDragging = true;
        });

        this.cardsContainer.addEventListener('mouseup', (e) => {
          if (this.isDragging) {
            this.touchEndX = e.screenX;
            this.handleSwipe();
            this.isDragging = false;
          }
        });

        this.cardsContainer.addEventListener('mouseleave', () => {
          this.isDragging = false;
        });
      }

      handleSwipe() {
        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0 && this.currentIndex < this.totalSlides - 1) {
            this.goToSlide(this.currentIndex + 1);
          } else if (diff < 0 && this.currentIndex > 0) {
            this.goToSlide(this.currentIndex - 1);
          }
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
      }

      updateCarousel() {
        if (this.isMobile) {
          const cardWidth = this.cards[0].offsetWidth;
          const gap = 12;
          const offset = -(cardWidth + gap) * this.currentIndex;
          this.cardsContainer.style.transform = `translateX(${offset}px)`;
        } else {
          const cardWidth = this.cards[0].offsetWidth;
          const gap = parseInt('{{ block.settings.card_gap }}');
          const offset = -(cardWidth + gap) * this.currentIndex;
          this.cardsContainer.style.transform = `translateX(${offset}px)`;
        }
        
        this.updateDots();
      }

      updateDots() {
        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('luxury-collection-highlight-{{ ai_gen_id }}', LuxuryCollectionHighlight{{ ai_gen_id }});
  })();
</script>


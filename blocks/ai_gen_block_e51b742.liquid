{% doc %}
  @prompt
    a custom design where icons are  set on the left hand side and the description is provided after the icons  the second icon must be placeed under the icon number 1 and its escription should be after the icon generate 7 icon custom template and the icon must be custom that can be changed with custom images 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-icon-list__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-icon-list__item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-icon-list__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background_color }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    padding: {{ block.settings.icon_padding }}px;
  }

  .ai-icon-list__icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-icon-list__icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.icon_placeholder_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-icon-list__icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-icon-list__content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-icon-list__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 600;
  }

  .ai-icon-list__description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-list-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-icon-list__icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<icon-list-{{ ai_gen_id }}
  class="ai-icon-list-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-icon-list__container-{{ ai_gen_id }}">
    {% for i in (1..7) %}
      {% liquid
        assign icon_key = 'icon_' | append: i
        assign title_key = 'title_' | append: i
        assign description_key = 'description_' | append: i

        assign icon = block.settings[icon_key]
        assign title = block.settings[title_key]
        assign description = block.settings[description_key]
      %}

      <div class="ai-icon-list__item-{{ ai_gen_id }}">
        <div class="ai-icon-list__icon-wrapper-{{ ai_gen_id }}">
          {% if icon %}
            <img
              src="{{ icon | image_url: width: 200 }}"
              alt="{{ title | escape }}"
              class="ai-icon-list__icon-{{ ai_gen_id }}"
              loading="lazy"
              width="200"
              height="200"
            >
          {% else %}
            <div class="ai-icon-list__icon-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        <div class="ai-icon-list__content-{{ ai_gen_id }}">
          {% if title != blank %}
            <h3 class="ai-icon-list__title-{{ ai_gen_id }}">{{ title }}</h3>
          {% endif %}
          {% if description != blank %}
            <p class="ai-icon-list__description-{{ ai_gen_id }}">{{ description }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</icon-list-{{ ai_gen_id }}>

<script>
  (function() {
    class IconList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('icon-list-{{ ai_gen_id }}', IconList{{ ai_gen_id }});
  })();
</script>

